# ==========================================
# Core Application Settings
# ==========================================
# The name of your application. Displayed in emails and the frontend.
APP_NAME=Timeflow
# The environment: "local" for development, "production" for live deployment.
APP_ENV=local
# The application key (generate using `php artisan key:generate`).
APP_KEY=
# Enable or disable debug mode (set to false in production).
APP_DEBUG=true
# Timezone for the application (default should generally remain UTC).
APP_TIMEZONE=UTC
# The public URL of the application (e.g. http://localhost:8000 or https://timeflow.app).
APP_URL=http://localhost

# Locale configuration
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ==========================================
# Database Configuration
# ==========================================
# Which database driver to use (mysql, pgsql, sqlite). MySQL 8+ is recommended.
DB_CONNECTION=mysql
# Database host address.
DB_HOST=127.0.0.1
# Database port.
DB_PORT=3306
# Database name.
DB_DATABASE=timeflow
# Database username.
DB_USERNAME=root
# Database password.
DB_PASSWORD=

# ==========================================
# Cache, Queue, & Session Drivers
# ==========================================
# It's recommended to use "redis" in production. "database" works out of the box.
BROADCAST_CONNECTION=log
CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database

SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ==========================================
# Redis Configuration (Optional)
# ==========================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==========================================
# Mail Configuration
# ==========================================
# SMTP details for sending outgoing emails (e.g., account deletion, password reset).
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@timeflow.app"
MAIL_FROM_NAME="${APP_NAME}"

# ==========================================
# Frontend Build Settings
# ==========================================
# The app name exposed directly to Vue/Inertia via Vite.
VITE_APP_NAME="${APP_NAME}"

# ==========================================
# Security & Sentry settings
# ==========================================
# Sentry DSN for backend error tracking (leave blank to disable).
SENTRY_LARAVEL_DSN=
# Sentry DSN for frontend (Vue) error tracking (leave blank to disable).
VITE_SENTRY_DSN_PUBLIC=

# ==========================================
# Web Push (VAPID) Settings
# ==========================================
# Generate these using `php artisan webpush:vapid`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:admin@timeflow.app"
VITE_VAPID_PUBLIC_KEY="${VAPID_PUBLIC_KEY}"
